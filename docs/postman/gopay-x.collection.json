{
  "info": {
    "name": "GoPayX API",
    "description": "Enterprise Digital Wallet & Payment Platform\n\n## Overview\nGoPayX is a production-ready microservices-based digital wallet platform built with Go.\n\n## Services\n- **API Gateway** :8080 — Single entry point\n- **Auth Service** :8081 — JWT Authentication\n- **User Service** :8082 — Profile & KYC\n- **Wallet Service** :8083 — Balance Management\n- **Payment Service** :8084 — Transfers & Gateway\n- **Transaction Service** :8085 — Immutable Ledger\n- **Notification Service** :8086 — Event-driven Alerts\n- **Fraud Detection** :8087 — Rule-based Scoring\n- **Audit Service** :8088 — Full Audit Trail\n\n## Authentication\nAll protected endpoints require `Bearer {{access_token}}` header.\nLogin first to get your token — it will be auto-injected via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "🏥 Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Check API Gateway health status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Service is api-gateway', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.equal('ok');",
                  "  pm.expect(json.service).to.equal('api-gateway');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "All Services Info",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/services",
            "description": "Get all registered service URLs"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has all services', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.services).to.have.property('auth-service');",
                  "  pm.expect(json.services).to.have.property('wallet-service');",
                  "  pm.expect(json.services).to.have.property('payment-service');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 Auth Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"{{user_email}}\",\n  \"phone\": \"081234567890\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "description": "Register a new user account"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user data', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.equal('registration successful');",
                  "  pm.expect(json.user).to.have.property('id');",
                  "  pm.expect(json.user).to.have.property('email');",
                  "  pm.environment.set('user_id', json.user.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "description": "Login and get JWT access + refresh token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has tokens', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('access_token');",
                  "  pm.expect(json.data).to.have.property('refresh_token');",
                  "  pm.environment.set('access_token', json.data.access_token);",
                  "  pm.environment.set('refresh_token', json.data.refresh_token);",
                  "  console.log('✅ Tokens saved to environment');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/validate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Validate current access token and get claims"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has claims', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('user_id');",
                  "  pm.expect(json.data).to.have.property('email');",
                  "  pm.environment.set('user_id', json.data.user_id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "description": "Get new access token using refresh token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('New tokens received', () => {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('access_token', json.data.access_token);",
                  "  pm.environment.set('refresh_token', json.data.refresh_token);",
                  "  console.log('✅ Tokens refreshed');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "description": "Logout and blacklist access token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Logout successful', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.equal('logout successful');",
                  "  pm.environment.set('access_token', '');",
                  "  pm.environment.set('refresh_token', '');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "👤 User Service",
