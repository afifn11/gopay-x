    {
      "name": "💳 Payment Service",
      "item": [
        {
          "name": "Transfer to User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/payments/transfer",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver_user_id\": \"RECEIVER_USER_ID_HERE\",\n  \"amount\": 50000,\n  \"reference_id\": \"transfer-{{$randomUUID}}\",\n  \"description\": \"Transfer test\"\n}"
            },
            "description": "Transfer funds to another user wallet"
          },
          "event": [
            {
              "listen": "prerequest",
