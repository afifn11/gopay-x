    {
      "name": "📊 Transaction Service",
      "item": [
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/transactions?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true },
                { "key": "from", "value": "", "disabled": true },
                { "key": "to", "value": "", "disabled": true }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "description": "Get paginated transaction history with optional filters:\n- `type`: top_up / transfer / withdraw / refund\n- `status`: success / failed / pending\n- `from`: date (YYYY-MM-DD)\n- `to`: date (YYYY-MM-DD)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pagination data', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('total');",
                  "  pm.expect(json.data).to.have.property('data');",
                  "  if (json.data.data.length > 0) {",
                  "    pm.environment.set('transaction_id', json.data.data[0].id);",
